{
    "tasks": [
        {
            "type": "cppbuild",
            "label": "C/C++: g++-13 build active file",
            "command": "/usr/bin/g++-13",
            "args": [
                        "-g",
                        "*.cpp",  // Compila todos os arquivos .cpp automaticamente
                        "-o",
                        "main",   // Nome do executável gerado
                        "-lGL",
                        "-lGLU",
                        "-lglut"
                    ],
            "options": {
                "cwd": "${fileDirname}"
            },
            "problemMatcher": [
                "$gcc"
            ],
            "group": {
                "kind": "build",
                "isDefault": true
            },
            "detail": "Task generated by Debugger."
        }
    ],
    "version": "2.0.0"
}